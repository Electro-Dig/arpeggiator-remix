# Optional local server settings
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
PORT=8000
NODE_ENV=development

# Netlify invite gate settings
# Set these in the Netlify dashboard or with the Netlify CLI, not in .env.
INVITE_CODE=change-me
# Optional: comma-separated list, used when more than one invite code is needed.
INVITE_CODES=change-me,another-code
# Required: long random secret used to sign the browser cookie.
INVITE_SECRET=change-me-to-a-long-random-secret
